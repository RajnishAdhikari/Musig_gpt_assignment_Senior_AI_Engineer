DATABASE_URL=postgresql+asyncpg://musicgpt:musicgpt@localhost:5433/musicgpt_search
SQL_ECHO=0
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=1

DATASET_URL=https://lalals.s3.us-east-1.amazonaws.com/ai_backend_assets/technical_assessment_datasets/song_metadata.json
DATASET_PATH=data/song_metadata.json
DATASET_DOWNLOAD_TIMEOUT_SECONDS=120

FEEDBACK_FLUSH_INTERVAL_SECONDS=5.0
FEEDBACK_FLUSH_BATCH_SIZE=25000
DEFAULT_SEARCH_LIMIT=10
DEFAULT_RETRIEVAL_LIMIT=100

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
